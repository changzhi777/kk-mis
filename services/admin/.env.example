# admin 服务环境变量模板 — 复制为 .env 后填实际值

# 监听
APP_HOST=0.0.0.0
APP_PORT=8300

# 数据库（dev: sqlite | prod: postgres）
DB_DRIVER=sqlite
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=KkMis2026Pg
# POSTGRES_DB=kk_admin

# Redis（DB 1 与 meeting-notes 区分）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=1

# JWT — 必须与 meeting-notes 一致
JWT_SECRET=kk-mis-jwt-secret-change-in-prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE=7200
REFRESH_TOKEN_EXPIRE=604800

# 首次启动 seed 的超管
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=admin1234

# OAuth GitHub（可选，未启用 OAuth 时留空）
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URI=https://aisport.tech/oa/admin/api/v1/auth/oauth/github/callback

LOG_LEVEL=INFO

# ── VIP 卡定价 + 区域代理（决策 #3 重构 2026-07-13） ────────────────
# VIP 单卡标准单价（默认 1888；可被 AssetCardType.unit_price / AssetCardBatch.unit_price 覆盖）
VIP_CARD_UNIT_PRICE=1888.00
# 防伪核销 URL 前缀（公开核销页 + QR 扫码目标）
ANTICOUNTERFEIT_BASE_URL=https://aisport.tech/oa/verify