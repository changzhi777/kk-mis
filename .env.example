# ===== 智谱 GLM API =====
# 申请地址: https://open.bigmodel.cn/
GLM_API_KEY=your-glm-api-key-here
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4.7
# 可选: glm-4.7 / glm-4-plus / glm-4-flash / glm-4-air / glm-4-long

# ===== 数据库 =====
# 驱动开关：sqlite（开发零配置）/ postgres（生产推荐）
DB_DRIVER=sqlite
# 仅 SQLite 模式用：
SQLITE_PATH=./storage/kk_mis.db
# 仅 PostgreSQL 模式用（设 DB_DRIVER=postgres 后生效）：
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=kk_mis

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== 应用 =====
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
APP_SECRET_KEY=please-change-me

# ===== 文件存储 =====
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=500

# ===== ASR 服务商（按需启用）=====
# 阿里云通义听悟: https://aliyun.com/tingwu
ALIYUN_ASR_KEY=
ALIYUN_ASR_APPKEY=