# meeting-notes 服务环境变量模板 — 复制为 .env 后填实际值

# 监听
APP_HOST=0.0.0.0
APP_PORT=8200

# 数据库（dev: sqlite | prod: postgres）
DB_DRIVER=sqlite
# POSTGRES_HOST=127.0.0.1
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=KkMis2026Pg
# POSTGRES_DB=kk_mis

# Redis（DB 0 与 admin 区分）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# JWT — 必须与 admin 一致
JWT_SECRET=kk-mis-jwt-secret-change-in-prod

# ASR 集群 / 节点
ASR_CLUSTER_URL=http://localhost:9100
DEFAULT_ASR_NODE_URL=http://100.88.88.34:9000
MLX_ASR_API_KEY=kk-mis-asr-local-dev-key-2026

# LLM 提供商（至少配一项）
GLM_API_KEY=
GLM_MODEL=glm-4.7
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-Text-01

# 本地 oMLX（可选）
OMLX_ENABLED=true
OMLX_BASE_URL=http://localhost:8008/v1
OMLX_MODEL=gemma-4-e4b-it-4bit

# 上传限制
MAX_UPLOAD_MB=500

LOG_LEVEL=INFO