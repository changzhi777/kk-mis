# admin 服务环境变量模板 — 复制为 .env 后填实际值

# 监听
APP_HOST=0.0.0.0
APP_PORT=8300

# 数据库（dev: sqlite | prod: postgres）
DB_DRIVER=sqlite
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=KkMis2026Pg
# POSTGRES_DB=kk_admin

# Redis（DB 1 与 meeting-notes 区分）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=1

# JWT — 必须与 meeting-notes 一致
JWT_SECRET=kk-mis-jwt-secret-change-in-prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE=7200
REFRESH_TOKEN_EXPIRE=604800

# 首次启动 seed 的超管
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=admin1234

# OAuth GitHub（可选，未启用 OAuth 时留空）
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URI=https://aisport.tech/oa/admin/api/v1/auth/oauth/github/callback

LOG_LEVEL=INFO

# ── VIP 卡定价 + 区域代理（决策 #3 重构 2026-07-13） ────────────────
# VIP 单卡标准单价（默认 1888；可被 AssetCardType.unit_price / AssetCardBatch.unit_price 覆盖）
VIP_CARD_UNIT_PRICE=1888.00
# 防伪核销 URL 前缀（公开核销页 + QR 扫码目标）
ANTICOUNTERFEIT_BASE_URL=https://aisport.tech/oa/verify

# ── 和风天气（CMS 旅游产品/行程设计参考，复用 QM-WX 凭据） ────────────────
# 无 KEY 时走 stub 兜底（不阻塞）；prod 填实际凭据
QWEATHER_KEY=your-qweather-api-key
QWEATHER_API_HOST=nf5b5vtkcp.re.qweatherapi.com

# ── webhook 通知（新线索/订单提醒运营；企业微信/钉钉/Slack/自定义；留空=不通知） ──
NOTIFY_WEBHOOK_URL=

# ── Storage 抽象层（2026-07-14 Sprint 0 引入，Phase 0 默认 local）──
# backend: 'local'（默认，写 ./storage/uploads）| 'cos'（Phase 1 实装）
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=storage/uploads

# ── 腾讯云 COS（Phase 1 实装，本 Sprint 0 不读） ──
# 推荐用 CAM 子账号 + STS 临时凭证，不要用主账号 Long-Term Key
# COS_REGION=ap-guangzhou
# COS_SECRET_ID=AKIDxxxxxxxxxxxxxxxxxxxx
# COS_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# COS_BUCKET=szdhts-prod-1300000000
# COS_APPID=1300000000
# COS_SCHEME=https
# COS_CDN_DOMAIN=cdn.example.com
# COS_PRESIGN_EXPIRE=3600
# COS_DOWNLOAD_EXPIRE=600
# COS_MAX_OBJECT_MB=500

# ── STS 临时凭证（Phase 2 用；留空时 CosStorage 用 Long-Term Key） ──
# STS_ROLE_ARN=qcs::cam::uin/10001:roleName/kk-mis-cos-writer
# STS_SESSION_NAME=kk-mis-session
# STS_SESSION_DURATION=1800
# STS_POLICY={"version":"2.0","statement":[{"effect":"allow","action":["name/cos:PutObject","name/cos:GetObject","name/cos:HeadObject","name:cos:DeleteObject"],"resource":["qcs::cos:ap-guangzhou:uid/1418512491:qm-wx-1418512491/*"]}]}

# === CMS 真支付 P0 2026-07-15 ===
PAYMENT_PROVIDER=mock  # 生产改为 wechat | alipay
PAYMENT_SIGNATURE_TOLERANCE_SECONDS=300
PAYMENT_IDEMPOTENCY_TTL_SECONDS=604800
PAYMENT_RETRY_POLL_SECONDS=30
# 微信支付 v3（生产配）
WECHAT_PAY_MCH_ID=
WECHAT_PAY_APP_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_MCH_SERIAL_NO=
WECHAT_PAY_PLATFORM_CERT_PATH=
WECHAT_PAY_MCH_PRIVATE_KEY_PATH=
WECHAT_PAY_NOTIFY_URL=
# 支付宝（暂不启用）
ALIPAY_APP_ID=
ALIPAY_PUBLIC_KEY_PATH=
ALIPAY_PRIVATE_KEY_PATH=
